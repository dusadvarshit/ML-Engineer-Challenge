# Docker Compose secrets. Copy to .env and replace every placeholder.
POSTGRES_USER=mlchallenge
POSTGRES_PASSWORD=replace-with-a-long-random-password
API_KEYS={"local-client":{"api_key":"replace-with-a-random-api-key","tier":"standard"}}
RATE_LIMITS_PER_MINUTE=standard:60,premium:300
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-password

# Local non-container defaults (optional).
DATABASE_URL=postgresql+psycopg2://mlchallenge:replace-with-a-long-random-password@localhost:5432/mlchallenge
REDIS_URL=redis://localhost:6379/0
YOLO_MODEL_DIR=models/artifacts/object_detection/yolov8n/v1.0.0/pytorch
REQUEST_LOGGING_ENABLED=true
